      'wolf-hide':         { type:'misc', bulk:1, desc:'Thick pelt from a wild wolf. Valuable to tanners and crafters.', mods:[{stat:'Sell Value',val:'~2 GP'},{stat:'Crafting',val:'Leather items'}] },
      'iron-ore':          { type:'misc', bulk:1, desc:'Raw iron suitable for smelting into weapons or armor.', mods:[{stat:'Sell Value',val:'~1 GP'},{stat:'Crafting',val:'Metal items'}] },
      'herbs':             { type:'misc', bulk:0, desc:'Gathered herbs useful for alchemical concoctions and poultices.', mods:[{stat:'Crafting',val:'Alchemical items'},{stat:'Medicine',val:'Poultice'}] },
      'gemstone':          { type:'misc', bulk:0, desc:'A rough-cut gemstone. Worth 10-50 GP depending on quality.', mods:[{stat:'Sell Value',val:'10-50 GP'}] },

      /* === COLLECTIBLES (tavern / quest items) === */
      'ancient-spellbook': { type:'misc', bulk:0, desc:'An ancient spellbook bound in cracked leather, its pages filled with arcane formulae.', mods:[{stat:'Quest',val:'Collectible'},{stat:'Arcana',val:'Study'}] },
      'mystical-tome':     { type:'misc', bulk:0, desc:'A tome radiating faint magical energy. Its contents shift when read by candlelight.', mods:[{stat:'Quest',val:'Collectible'},{stat:'Occultism',val:'Study'}] },
      'faded-journal':     { type:'misc', bulk:0, desc:'A water-stained journal with barely legible entries. May contain clues to forgotten places.', mods:[{stat:'Quest',val:'Collectible'},{stat:'Lore',val:'Clues'}] },
      'crystal-bound-codex': { type:'misc', bulk:1, desc:'A codex sealed with crystalline clasps that hum with latent power.', mods:[{stat:'Quest',val:'Collectible'},{stat:'Arcana',val:'Rare text'}] },
      'torch-rod':         { type:'misc', bulk:0, desc:'A sturdy wooden rod shaped to hold wrapping for a torch. A torch component.', mods:[{stat:'Crafting',val:'Torch'}] },
      'cloth-wrapping':    { type:'misc', bulk:0, desc:'Strips of tallow-soaked cloth for wrapping torch rods. A torch component.', mods:[{stat:'Crafting',val:'Torch'}] },
      'flint-stone':       { type:'misc', bulk:0, desc:'A sharp piece of flint for striking sparks. A torch component.', mods:[{stat:'Crafting',val:'Torch / fire'}] },
      'wine-bottle':       { type:'misc', bulk:0, desc:'A bottle of tavern wine. Decent vintage, better than nothing on a cold night.', mods:[{stat:'Sell Value',val:'~5 SP'},{stat:'Morale',val:'Warm'}] }
    };

    function getItemInfo(itemId, name) {
      var info = ITEM_DB[itemId];
      if (info) return info;
      // Try underscore→hyphen (DB IDs use underscores, ITEM_DB uses hyphens)
      var hyphenated = (itemId || '').replace(/_/g, '-');
      if (ITEM_DB[hyphenated]) return ITEM_DB[hyphenated];
      // Fuzzy match by display name
      var slug = (name || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-+$/, '').replace(/^-+/, '');
      if (ITEM_DB[slug]) return ITEM_DB[slug];
      // Try without trailing quantity like "(5)" or "(1 week)"
      var cleaned = (name || '').replace(/\s*\(.*?\)\s*$/, '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-+$/, '').replace(/^-+/, '');
      if (cleaned !== slug && ITEM_DB[cleaned]) return ITEM_DB[cleaned];
      return null;
    }

    /* ---- Tooltip System ---- */
    var tooltip = document.createElement('div');
    tooltip.className = 'inv-tooltip';
    tooltip.style.display = 'none';
    document.body.appendChild(tooltip);
    var activeTooltipElement = null;
    var spellTooltipCache = {};
    var spellTooltipPending = {};

    function escapeTooltipHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function parseTooltipJson(value) {
      if (!value) return [];
      try {
        var parsed = JSON.parse(value);
        return Array.isArray(parsed) ? parsed : [];
      } catch (e) {
        return [];
      }
    }

    function spellRankLabel(rank, isCantrip) {
      if (isCantrip || Number(rank) === 0) return 'Cantrip';
      var labels = { 1: '1st Rank', 2: '2nd Rank', 3: '3rd Rank' };
      return labels[rank] || (String(rank) + 'th Rank');
    }

    function humanizeSpellValue(value) {
      return String(value || '').replace(/_/g, ' ');
    }

    function positionTooltip(el) {
      var rect = el.getBoundingClientRect();
      var tipW = tooltip.offsetWidth;
      var tipH = tooltip.offsetHeight;
      var left = rect.left - tipW - 8;
      if (left < 8) left = rect.right + 8;
      var top = rect.top + (rect.height / 2) - (tipH / 2);
      if (top < 8) top = 8;
      if (top + tipH > window.innerHeight - 8) top = window.innerHeight - tipH - 8;
      tooltip.style.left = left + 'px';
      tooltip.style.top = top + 'px';
    }

    function renderTooltipContent(payload) {
      var html = '<div class="inv-tooltip__name">' + escapeTooltipHtml(payload.name || '') + '</div>';
      if (payload.type) html += '<div class="inv-tooltip__type">' + escapeTooltipHtml(payload.type) + '</div>';
      if (payload.desc) html += '<div class="inv-tooltip__desc">' + escapeTooltipHtml(payload.desc) + '</div>';

      if (payload.loading) {
        html += '<div class="inv-tooltip__loading">Loading full entry...</div>';
      }

      if (payload.stats && payload.stats.length) {
        html += '<div class="inv-tooltip__stats">';
        payload.stats.forEach(function (stat) {
          if (!stat || !stat.label || stat.value == null || stat.value === '') return;
          html += '<span class="inv-tooltip__stat"><b>' + escapeTooltipHtml(stat.label) + ':</b> ' + escapeTooltipHtml(stat.value) + '</span>';
        });
        html += '</div>';
      }

      if (payload.traits) html += '<div class="inv-tooltip__traits">' + escapeTooltipHtml(payload.traits) + '</div>';

      if (payload.effects && payload.effects.length) {
        html += '<div class="inv-tooltip__section">';
        html += '<div class="inv-tooltip__section-label">Effects</div>';
        html += '<ul class="inv-tooltip__list">';
        payload.effects.forEach(function (effect) {
          html += '<li>' + escapeTooltipHtml(effect) + '</li>';
        });
        html += '</ul></div>';
      }

      if (payload.mods && payload.mods.length) {
        html += '<div class="inv-tooltip__mods">';
        html += '<div class="inv-tooltip__mods-label">Modifiers</div>';
        payload.mods.forEach(function (m) {
          var cls = 'inv-tooltip__mod';
          if (typeof m.val === 'string' && m.val.charAt(0) === '+') cls += ' inv-tooltip__mod--pos';
          if (typeof m.val === 'string' && m.val.charAt(0) === '-') cls += ' inv-tooltip__mod--neg';
          html += '<span class="' + cls + '"><b>' + escapeTooltipHtml(m.stat || 'Effect') + '</b> ' + escapeTooltipHtml(m.val || '') + '</span>';
        });
        html += '</div>';
      }

      if (payload.notes && payload.notes.length) {
        html += '<div class="inv-tooltip__section">';
        html += '<div class="inv-tooltip__section-label">Notes</div>';
        html += '<ul class="inv-tooltip__list">';
        payload.notes.forEach(function (note) {
          html += '<li>' + escapeTooltipHtml(note) + '</li>';
        });
        html += '</ul></div>';
      }

      return html;
    }

    function collectTooltipPayload(el, info, itemName) {
      var dataDesc = el.dataset.tooltipDesc || el.dataset.desc || '';
      var dataBulk = el.dataset.bulk || '';
      var dataDamage = el.dataset.damage || '';
      var dataTraits = el.dataset.tooltipTraits || el.dataset.traits || '';
      var dataType = el.dataset.tooltipType || el.dataset.type || '';
      var dataStats = parseTooltipJson(el.dataset.tooltipStats);
      var dataMods = parseTooltipJson(el.dataset.tooltipMods);
      var dataEffects = parseTooltipJson(el.dataset.tooltipEffects);
      var dataNotes = parseTooltipJson(el.dataset.tooltipNotes);

      var desc = dataDesc || (info && (info.description || info.desc)) || (info && info.effect_text) || '';
      var bulk = dataBulk || (info && info.bulk != null ? info.bulk : '');
      var damage = dataDamage || (info && info.damage) || '';
      var traits = dataTraits || (info && Array.isArray(info.traits) ? info.traits.join(', ') : info && info.traits) || '';
      var ac = (info && info.ac) || '';
      var type = dataType || (info && info.type) || '';

      var stats = [];
      if (damage) stats.push({ label: 'Damage', value: damage });
      if (ac) stats.push({ label: 'AC', value: ac });
      if (bulk !== '') stats.push({ label: 'Bulk', value: bulk });
      stats = stats.concat(dataStats);

      return {
        name: itemName,
        type: type,
        desc: desc,
        stats: stats,
        traits: traits,
        effects: dataEffects,
        mods: dataMods.length ? dataMods : ((info && info.mods) || []),
        notes: dataNotes,
        loading: el.dataset.tooltipResolver === 'spell' && !!el.dataset.itemId && !el.dataset.tooltipLoaded
      };
    }

    function applySpellTooltipData(el, spell) {
      if (!spell || !el || el.dataset.tooltipLoaded === 'true') return;
      var stats = parseTooltipJson(el.dataset.tooltipStats);
      var effects = parseTooltipJson(el.dataset.tooltipEffects);
      var mods = parseTooltipJson(el.dataset.tooltipMods);
      var notes = parseTooltipJson(el.dataset.tooltipNotes);

      var rankLabel = spellRankLabel(spell.rank, spell.is_cantrip);
      var typeParts = [rankLabel, spell.school ? humanizeSpellValue(spell.school) : 'Spell'];
      el.dataset.tooltipType = typeParts.join(' · ');
      el.dataset.tooltipDesc = spell.description || spell.effect_text || el.dataset.tooltipDesc || '';
      if (Array.isArray(spell.traits) && spell.traits.length) {
        el.dataset.tooltipTraits = spell.traits.join(', ');
      }

      var extraStats = [];
      if (spell.cast_actions) extraStats.push({ label: 'Cast', value: humanizeSpellValue(spell.cast_actions) });
      if (spell.range) extraStats.push({ label: 'Range', value: spell.range });
      if (spell.area) extraStats.push({ label: 'Area', value: spell.area });
      if (spell.targets) extraStats.push({ label: 'Targets', value: spell.targets });
      if (spell.duration) extraStats.push({ label: 'Duration', value: spell.duration });
      if (spell.save_type) extraStats.push({ label: 'Save', value: humanizeSpellValue(spell.save_type) });
      if (spell.rarity) extraStats.push({ label: 'Rarity', value: spell.rarity });
      if (Array.isArray(spell.traditions) && spell.traditions.length) extraStats.push({ label: 'Traditions', value: spell.traditions.join(', ') });
      if (Array.isArray(spell.components) && spell.components.length) extraStats.push({ label: 'Components', value: spell.components.join(', ') });
      if (spell.essence) extraStats.push({ label: 'Essence', value: spell.essence });
      el.dataset.tooltipStats = JSON.stringify(stats.concat(extraStats));

      if (spell.effect_text) {
        effects.push(spell.effect_text);
      }
      if (Array.isArray(spell.heightened_entries)) {
        spell.heightened_entries.forEach(function (entry) {
          if (!entry) return;
          var label = entry.type === 'specific'
            ? 'Heightened (' + spellRankLabel(entry.rank, false) + ')'
            : 'Heightened (+' + (entry.rank_delta || 0) + ')';
          if (entry.additional_text) {
            effects.push(label + ': ' + entry.additional_text);
          } else if (entry.modified_fields) {
            effects.push(label + ': modified spell fields apply.');
          }
        });
      }
      if (spell.heightened_scaling && typeof spell.heightened_scaling === 'object') {
        Object.keys(spell.heightened_scaling).forEach(function (key) {
          mods.push({ stat: 'Heightened ' + key, val: spell.heightened_scaling[key] });
        });
      }
      if (spell.save) {
        mods.push({ stat: 'Save', val: spell.save });
      }
      if (spell.state_machine && typeof spell.state_machine === 'object') {
        Object.keys(spell.state_machine).forEach(function (key) {
          notes.push(humanizeSpellValue(key) + ': ' + spell.state_machine[key]);
        });
      }
      if (spell.mode_is_fixed_at_cast) {
        notes.push('Mode is fixed when the spell is cast.');
      }
      if (spell.modes && typeof spell.modes === 'object') {
        Object.keys(spell.modes).forEach(function (key) {
          var mode = spell.modes[key];
          if (mode && mode.description) {
            effects.push(humanizeSpellValue(key) + ': ' + mode.description);
          }
        });
      }
      if (spell.trigger) {
        notes.push('Trigger: ' + spell.trigger);
      }
      if (spell.eligible_caster_note) {
        notes.push(spell.eligible_caster_note);
      }
      if (spell.edge_case) {
        notes.push(spell.edge_case);
      }
      if (spell.summon_level_cap_table && typeof spell.summon_level_cap_table === 'object') {
        Object.keys(spell.summon_level_cap_table)
          .sort(function (a, b) { return Number(a) - Number(b); })
          .forEach(function (key) {
            notes.push('Animate Dead ' + spellRankLabel(Number(key), false) + ': max undead level ' + spell.summon_level_cap_table[key]);
          });
      }

      el.dataset.tooltipEffects = JSON.stringify(Array.from(new Set(effects.filter(Boolean))));
      el.dataset.tooltipMods = JSON.stringify(mods);
      el.dataset.tooltipNotes = JSON.stringify(Array.from(new Set(notes.filter(Boolean))));
      el.dataset.tooltipLoaded = 'true';
    }

    function fetchSpellTooltip(itemId) {
      if (!itemId) return Promise.resolve(null);
      if (spellTooltipCache[itemId]) return Promise.resolve(spellTooltipCache[itemId]);
      if (spellTooltipPending[itemId]) return spellTooltipPending[itemId];

      spellTooltipPending[itemId] = fetch('/api/spells/' + encodeURIComponent(itemId), { credentials: 'same-origin' })
        .then(function (response) {
          if (!response.ok) return null;
          return response.json();
        })
        .then(function (data) {
          if (data) spellTooltipCache[itemId] = data;
          delete spellTooltipPending[itemId];
          return data;
        })
        .catch(function () {
          delete spellTooltipPending[itemId];
          return null;
        });

      return spellTooltipPending[itemId];
    }

    function showTooltip(el) {
      var itemId = el.dataset.itemId || '';
      var itemName = el.dataset.tooltipName || '';
      if (!itemName) {
        var name = el.querySelector('.inv-item__name');
        itemName = name ? name.textContent : el.textContent.trim();
      }
      var info = getItemInfo(itemId, itemName);
      activeTooltipElement = el;
      tooltip.innerHTML = renderTooltipContent(collectTooltipPayload(el, info, itemName));
      tooltip.style.display = 'block';
      positionTooltip(el);

      if (el.dataset.tooltipResolver === 'spell' && itemId) {
        fetchSpellTooltip(itemId).then(function (spell) {
          if (!document.body.contains(el)) return;
          if (!spell) {
            el.dataset.tooltipLoaded = 'missing';
            return;
          }
          applySpellTooltipData(el, spell);
          if (activeTooltipElement === el) {
            tooltip.innerHTML = renderTooltipContent(collectTooltipPayload(el, info, itemName));
            tooltip.style.display = 'block';
            positionTooltip(el);
          }
        });
      }
    }

    function toggleTooltip(el) {
      if (activeTooltipElement === el && tooltip.style.display === 'block') {
        hideTooltip();
        return;
      }
      showTooltip(el);
    }

    function hideTooltip() {
      activeTooltipElement = null;
      tooltip.style.display = 'none';
    }

    function attachTooltips(container) {
      container.querySelectorAll('.inv-item, [data-tooltip-enabled="true"]').forEach(function (el) {
        if (el.dataset.tooltipBound === 'true') return;
        el.dataset.tooltipBound = 'true';
        if (!el.hasAttribute('tabindex')) el.setAttribute('tabindex', '0');
        el.addEventListener('mouseenter', function () { showTooltip(this); });
        el.addEventListener('mouseleave', hideTooltip);
        el.addEventListener('focus', function () { showTooltip(this); });
        el.addEventListener('blur', hideTooltip);
        el.addEventListener('click', function (event) {
          event.preventDefault();
          event.stopPropagation();
          toggleTooltip(this);
        });
        el.addEventListener('keydown', function (event) {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            toggleTooltip(this);
          } else if (event.key === 'Escape') {
            hideTooltip();
          }
        });
      });
    }

    document.addEventListener('click', function (event) {
      if (tooltip.contains(event.target)) return;
      if (event.target.closest('.inv-item, [data-tooltip-enabled="true"]')) return;
      hideTooltip();
    });

    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') hideTooltip();
    });

    /* ---- Inventory Sync (mirrors char-sheet data) ---- */
    function syncInventory() {
      // Currency — copy from character sheet
      var gp = document.getElementById('char-gp');
      var sp = document.getElementById('char-sp');
      var cp = document.getElementById('char-cp');
      if (gp) document.getElementById('inv-gp').textContent = gp.textContent;
      if (sp) document.getElementById('inv-sp').textContent = sp.textContent;
      if (cp) document.getElementById('inv-cp').textContent = cp.textContent;

      // Items — clone from character sheet inventory list
      var srcList = document.getElementById('char-inventory');
      var dstList = document.getElementById('inv-item-list');
      if (!srcList || !dstList) return;

      var items = srcList.querySelectorAll('li:not(.inventory-empty)');
      if (items.length === 0) {
        dstList.innerHTML = '<li class="inventory-panel__empty">No items in inventory</li>';
        return;
      }

      dstList.innerHTML = '';
      items.forEach(function (li) {
        var text = li.textContent.trim();
        var itemId = li.dataset.itemId || '';
        var info = getItemInfo(itemId, text);
        var rawType = li.dataset.type || (info && info.type) || 'utility';
        // Normalize legacy type names → current categories
        var typeMap = { adventuring_gear:'utility', gear:'utility', potion:'consumable', alchemical:'consumable' };
        var type = typeMap[rawType] || rawType;
        var qty  = li.dataset.qty || '';
        var bulk = li.dataset.bulk || (info && info.bulk != null ? String(info.bulk) : '');
        var desc = li.dataset.desc || (info && info.desc) || '';
        var icon = { weapon: 'W', armor: 'A', consumable: 'C', utility: 'U', misc: 'M' }[type] || 'I';
        var el = document.createElement('li');
        el.className = 'inv-item';
        el.dataset.type = type;
        el.dataset.itemId = itemId;
        el.dataset.desc = desc;
        el.dataset.bulk = bulk;
        if (info && info.damage) el.dataset.damage = info.damage;
        if (info && info.traits) el.dataset.traits = info.traits;
        el.innerHTML =
          '<span class="inv-item__icon">' + icon + '</span>' +
          '<div class="inv-item__info">' +
            '<div class="inv-item__name">' + text + '</div>' +
            '<div class="inv-item__meta">' + type + (bulk ? ' · Bulk ' + bulk : '') + '</div>' +
          '</div>' +
          (qty && parseInt(qty) > 1 ? '<span class="inv-item__qty">×' + qty + '</span>' : '');
        dstList.appendChild(el);
      });

      attachTooltips(dstList);
    }

    /* ---- Inventory Filter ---- */
    var filterBtns = document.querySelectorAll('.inv-filter');
    filterBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        filterBtns.forEach(function (b) { b.classList.remove('inv-filter--active'); });
        this.classList.add('inv-filter--active');
        var filter = this.dataset.filter;
        var items = document.querySelectorAll('#inv-item-list .inv-item');
        items.forEach(function (item) {
          if (filter === 'all' || item.dataset.type === filter) {
            item.style.display = '';
          } else {
            item.style.display = 'none';
          }
        });
      });
    });

    // Sync on initial load if inventory tab was remembered
    if (saved === 'inventory') syncInventory();

    // Expose syncInventory globally so hexmap.js can call it after data loads
    window.dcSyncInventory = syncInventory;
    window.dcAttachTooltips = attachTooltips;
  })();

  /* ---- Sidebar Drawer Toggle ---- */
  (function () {
    var btn = document.getElementById('sidebar-drawer-toggle');
    var layout = document.getElementById('game-layout');
    var backdrop = document.getElementById('sidebar-backdrop');
    if (!btn || !layout) return;
    var DRAWER_KEY = 'dc_drawer_open';

    function isMobile() {
      return window.matchMedia('(max-width: 768px)').matches;
    }

    function setDrawerOpen(open) {
      if (isMobile()) {
        layout.classList.toggle('game-layout--drawer-open', open);
        layout.classList.remove('game-layout--drawer-collapsed');
        if (backdrop) backdrop.hidden = !open;
      } else {
        layout.classList.toggle('game-layout--drawer-collapsed', !open);
        layout.classList.remove('game-layout--drawer-open');
        if (backdrop) backdrop.hidden = true;
      }
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      btn.textContent = isMobile() ? (open ? '✕' : '☰') : (open ? '⟩' : '⟨');
      localStorage.setItem(DRAWER_KEY, open ? '1' : '0');
    }

    // Restore saved preference; default open on desktop, closed on mobile
    var saved = localStorage.getItem(DRAWER_KEY);
    if (saved !== null) {
      setDrawerOpen(saved === '1');
    } else {
      setDrawerOpen(!isMobile());
    }

    btn.addEventListener('click', function () {
      var isOpen = isMobile()
        ? layout.classList.contains('game-layout--drawer-open')
        : !layout.classList.contains('game-layout--drawer-collapsed');
      setDrawerOpen(!isOpen);
    });

    if (backdrop) {
      backdrop.addEventListener('click', function () {
        setDrawerOpen(false);
      });
    }

    // Re-apply on resize (desktop ↔ mobile transition)
    window.addEventListener('resize', function () {
      var saved2 = localStorage.getItem(DRAWER_KEY);
      if (saved2 !== null) setDrawerOpen(saved2 === '1');
    });
  })();

  /* ---- Chat Dock Toggle ---- */
  (function () {
    var btn = document.getElementById('chat-dock-toggle');
    var chat = document.getElementById('hexmap-chat');
    if (!btn || !chat) return;
    var CHAT_KEY = 'dc_chat_collapsed';

    function setChatCollapsed(collapsed) {
      chat.classList.toggle('hexmap-chat--collapsed', collapsed);
      btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
      btn.textContent = collapsed ? '▴' : '▾';
      btn.title = _dt(collapsed ? 'Expand chat' : 'Collapse chat');
      localStorage.setItem(CHAT_KEY, collapsed ? '1' : '0');
    }

    var saved = localStorage.getItem(CHAT_KEY);
    setChatCollapsed(saved === '1');

    btn.addEventListener('click', function () {
      setChatCollapsed(!chat.classList.contains('hexmap-chat--collapsed'));
    });
  })();

  </script>

  <div id="sidebar-backdrop" class="sidebar-backdrop" hidden></div>
</div>
