# DungeonCrawler Content Configuration

# AI Provider (gemini, vertex, etc)
DUNGEONCRAWLER_AI_PROVIDER=gemini

# Google Gemini API
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
DUNGEONCRAWLER_LLM_MODEL=gemini-pro

# Google Vertex AI (alternative)
# DUNGEONCRAWLER_AI_PROVIDER=vertex
# VERTEX_API_PROJECT=your-project-id
# VERTEX_API_KEY=YOUR_VERTEX_API_KEY

# Generation Parameters
DUNGEONCRAWLER_GENERATION_TIMEOUT=30
DUNGEONCRAWLER_MAX_CREATURES=100

# Difficulty Scaling
DUNGEONCRAWLER_DIFFICULTY_SCALE=1.0
DUNGEONCRAWLER_ENABLE_DIFFICULTY_ADAPTATION=true

# Cache
DUNGEONCRAWLER_CACHE_TTL=300
DUNGEONCRAWLER_STATE_PERSISTENCE=true
