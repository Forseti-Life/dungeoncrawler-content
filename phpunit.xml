<?xml version="1.0" encoding="UTF-8"?>
<!--
  PHPUnit Configuration for Dungeon Crawler content module.

  Usage:
    cd /var/www/html/dungeoncrawler
    export SIMPLETEST_DB='mysql://user:pass@127.0.0.1:3306/database'
    export SIMPLETEST_BASE_URL='http://localhost'
    ./vendor/bin/phpunit -c web/modules/custom/dungeoncrawler_content/phpunit.xml

  Notes:
    - Uses a custom tests/bootstrap.php so Drupal core bootstrap still resolves
      correctly when this module is symlinked into the live Drupal install.
    - Functional tests require SIMPLETEST_DB to be provided by the local or CI
      environment. Do not commit database credentials here.
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.5/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         cacheResult="false"
         failOnPhpunitDeprecation="false"
         failOnWarning="false"
         failOnDeprecation="false"
         failOnNotice="false"
         failOnRisky="false"
         failOnIncomplete="false">

  <testsuites>
    <testsuite name="unit">
      <directory>tests/src/Unit</directory>
      <exclude>tests/src/Unit/Traits</exclude>
    </testsuite>

    <testsuite name="kernel">
      <directory>tests/src/Kernel</directory>
    </testsuite>

    <testsuite name="functional">
      <directory>tests/src/Functional</directory>
    </testsuite>
  </testsuites>

  <source>
    <include>
      <directory suffix=".php">src</directory>
    </include>
    <exclude>
      <directory>tests</directory>
    </exclude>
  </source>

  <php>
    <env name="SIMPLETEST_BASE_URL" value="http://localhost:8080"/>
    <env name="BROWSERTEST_OUTPUT_DIRECTORY" value="../../../../sites/simpletest/browser_output"/>
    <env name="SYMFONY_DEPRECATIONS_HELPER" value="disabled"/>
    <ini name="memory_limit" value="512M"/>
  </php>

</phpunit>
