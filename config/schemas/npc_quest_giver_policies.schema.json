{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dungeoncrawler.life/schemas/npc_quest_giver_policies.schema.json",
  "title": "NPC Quest Giver Policies Schema",
  "description": "Canonical allowlist registry for which quest templates and storyline templates an NPC may issue.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policies"],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["npc-quest-giver-policies-v1"]
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["policy_id", "giver_ids", "allowed_quest_template_ids", "allowed_storyline_template_ids", "notes"],
        "properties": {
          "policy_id": { "type": "string", "minLength": 1, "maxLength": 160 },
          "giver_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1, "maxLength": 160 }
          },
          "allowed_quest_template_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1, "maxLength": 160 }
          },
          "allowed_storyline_template_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1, "maxLength": 160 }
          },
          "notes": { "type": "string", "maxLength": 2000 }
        }
      }
    }
  }
}
